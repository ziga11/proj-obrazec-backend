{
        "compilerOptions": {
                "outDir": "./dist",
                "rootDir": "./src",
                "module": "NodeNext",
                "target": "ES2022",
                "types": [
                        "node",
                        "express"
                ],
                "moduleResolution": "NodeNext",
                "allowSyntheticDefaultImports": true,
                "skipLibCheck": true
        },
        "include": [
                "src/**/*"
        ],
        "exclude": [
                "node_modules"
        ]
}
